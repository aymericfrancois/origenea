# Connexion à Sanity (CMS headless)
# Copier ce fichier en `.env` et renseigner les valeurs (.env est gitignoré).

# Project ID Sanity — visible sur https://www.sanity.io/manage
PUBLIC_SANITY_PROJECT_ID=ton_project_id

# Dataset (par défaut "production")
PUBLIC_SANITY_DATASET=production

# Token de lecture — UNIQUEMENT si le dataset est privé.
# Laisser vide si le dataset est public.
# SANITY_API_READ_TOKEN=
