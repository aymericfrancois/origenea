---
import Base from '../layouts/Base.astro';
import { getSiteInfo, getPageAccueil } from '../lib/sanity';

const siteInfo = await getSiteInfo();
const page = await getPageAccueil();

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Origenea — Cabinet de généalogie familiale",
  "description": "Cabinet de généalogie familiale et foncière, sous-traitance successorale, à Libourne en Gironde.",
  "founder": "Catherine Fougeray-Imbrechts",
  "areaServed": ["Libourne", "Saint-Émilion", "Bordeaux", "Gironde", "Nouvelle-Aquitaine"],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "12 rue Montesquieu",
    "addressLocality": "Libourne",
    "postalCode": "33500",
    "addressRegion": "Gironde",
    "addressCountry": "FR"
  },
  "telephone": "+33557251234",
  "email": "contact@origenea.fr",
  "url": "https://www.origenea.fr"
});
---

<Base
  title="Origenea — Cabinet de généalogie familiale à Libourne (Gironde)"
  description="Origenea, cabinet de généalogie de Catherine Fougeray-Imbrechts à Libourne. Recherches d'ascendance, arbres généalogiques, généalogie foncière et sous-traitance successorale en Gironde et Nouvelle-Aquitaine."
  currentPage="index"
  schema={schema}
>

<!-- ============================ HERO ============================ -->
<section class="hero">
  <div class="wrap hero__grid">
    <div class="reveal">
      <span class="eyebrow">Cabinet de généalogie · Libourne, Gironde</span>
      <h1>{page?.heroTitre ?? "Retrouvez le fil de votre histoire familiale"}</h1>
      <p class="lead">{page?.heroLead ?? "Derrière chaque nom se cache une vie, un lieu, une époque. J'explore les archives pour reconstituer votre ascendance et transmettre, aux générations suivantes, la mémoire des vôtres."}</p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="/services">
          Découvrir les services
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a class="btn btn--ghost" href="/contact">Échanger sur votre projet</a>
      </div>
    </div>
    <div class="reveal" data-delay="120">
      <figure class="medallion">
        <span class="hero__corner tl"></span>
        <span class="hero__corner tr"></span>
        <span class="hero__corner bl"></span>
        <span class="hero__corner br"></span>
        <span class="medallion__doc"></span>
        <img src="/assets/origenea-logo.png" alt="Logo Origenea : arbre généalogique, livre ouvert et silhouettes de famille" />
      </figure>
    </div>
  </div>
</section>

<!-- ============================ TRUST ============================ -->
<section class="section--tight">
  <div class="wrap">
    <div class="trust reveal">
      {page?.trustItems && page.trustItems.length > 0 ? (
        page.trustItems.map((item) => (
          <div class="trust__item">
            <span class="trust__num">{item.valeur}</span>
            <span class="trust__lbl">{item.libelle}</span>
          </div>
        ))
      ) : (
        <>
          <div class="trust__item">
            <span class="trust__num">+15 ans</span>
            <span class="trust__lbl">de recherches en archives</span>
          </div>
          <div class="trust__item">
            <span class="trust__num">4 à 12</span>
            <span class="trust__lbl">générations remontées</span>
          </div>
          <div class="trust__item">
            <span class="trust__num">Gironde</span>
            <span class="trust__lbl">& Nouvelle-Aquitaine</span>
          </div>
          <div class="trust__item">
            <span class="trust__num">Sur devis</span>
            <span class="trust__lbl">étude personnalisée</span>
          </div>
        </>
      )}
    </div>
  </div>
</section>

<!-- ============================ INTRO / SIGNATURE ============================ -->
<section class="section band-paper2 band-edge-top band-edge-bottom">
  <div class="wrap narrow" style="text-align:center">
    <span class="eyebrow reveal" style="justify-content:center">Le mot de Catherine</span>
    <p class="reveal" style="font-family:var(--font-display);font-weight:var(--display-weight);font-size:clamp(1.5rem,3vw,2.05rem);line-height:1.35;color:var(--ink-strong);letter-spacing:var(--display-tracking);margin-bottom:1.2em">
      {page?.citationCatherine ?? "« Comprendre d'où l'on vient, c'est mieux savoir qui l'on est. Mon métier consiste à redonner un visage et une histoire à des noms parfois oubliés. »"}
    </p>
    <p class="reveal lead">{page?.introParagraphe ?? "Je suis Catherine Fougeray-Imbrechts, généalogiste à Libourne. Patiemment, document après document, je remonte le temps avec vous — registres paroissiaux, actes notariés, recensements, cadastre — pour bâtir un récit fiable, sourcé et transmissible."}</p>
    <p class="reveal" data-delay="80" style="margin-top:26px">
      <a class="link-arrow" href="/a-propos">
        Découvrir mon parcours
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </p>
  </div>
</section>

<!-- ============================ SERVICES ============================ -->
<section class="section">
  <div class="wrap">
    <div style="max-width:640px;margin-bottom:48px">
      <span class="eyebrow reveal">Ce que je peux faire pour vous</span>
      <h2 class="reveal">Des recherches sur mesure, du premier indice au récit complet</h2>
    </div>
    <div class="grid grid-3">
      <a class="card card--link reveal" href="/services">
        <span class="card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M12 3v6m0 0c-2-1-4-3-4-5M12 9c2-1 4-3 4-5M12 21v-7m0 0c-3-1-6-1-9-3m9 3c3-1 6-1 9-3" stroke-linecap="round"/>
            <circle cx="12" cy="3" r="1.3" fill="currentColor"/>
          </svg>
        </span>
        <h3>Généalogie familiale</h3>
        <p>Recherches ascendantes en ligne agnatique (paternelle) ou cognatique (maternelle), et reconstitution du parcours d'un ancêtre.</p>
        <ul class="card__list">
          <li>Arbres généalogiques 4, 5 générations et au-delà</li>
          <li>Étude d'une branche ou d'un aïeul précis</li>
        </ul>
      </a>
      <a class="card card--link reveal" data-delay="100" href="/services">
        <span class="card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M4 21V8l8-5 8 5v13M4 21h16M9 21v-5h6v5M8 11h.01M12 11h.01M16 11h.01" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <h3>Généalogie foncière</h3>
        <p>L'histoire d'un bâtiment ou d'une propriété, et l'identification des propriétaires successifs à travers les siècles.</p>
        <ul class="card__list">
          <li>Histoire d'une maison, d'un domaine</li>
          <li>Chaîne de propriété et cadastre ancien</li>
        </ul>
      </a>
      <a class="card card--link reveal" data-delay="200" href="/services">
        <span class="card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M7 3h7l4 4v14H7z M14 3v4h4M9.5 12h5M9.5 15.5h5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <h3>Sous-traitance successorale</h3>
        <p>Un appui fiable pour notaires et généalogistes successoraux : recherches d'héritiers et reconstitution de dévolutions.</p>
        <ul class="card__list">
          <li>Recherches d'héritiers et de filiations</li>
          <li>Appui documentaire pour études notariales</li>
        </ul>
      </a>
    </div>
    <p class="reveal" data-delay="120" style="margin-top:36px">
      <a class="link-arrow" href="/services">
        Voir le détail des prestations
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </p>
  </div>
</section>

<!-- ============================ PROCESS ============================ -->
<section class="section band-paper3 band-edge-top band-edge-bottom">
  <div class="wrap">
    <div style="max-width:640px;margin-bottom:48px">
      <span class="eyebrow reveal">Comment se déroule une étude</span>
      <h2 class="reveal">Une démarche claire, à votre rythme</h2>
    </div>
    <div class="steps">
      <div class="step reveal">
        <span class="step__line"></span>
        <h4>Premier échange</h4>
        <p>Nous définissons ensemble votre objectif, ce que vous savez déjà et ce que vous souhaitez transmettre.</p>
      </div>
      <div class="step reveal" data-delay="100">
        <span class="step__line"></span>
        <h4>Recherches en archives</h4>
        <p>Dépouillement des registres, actes et fonds publics — sur place en Gironde et en ligne.</p>
      </div>
      <div class="step reveal" data-delay="200">
        <span class="step__line"></span>
        <h4>Constitution du dossier</h4>
        <p>Chaque information est vérifiée, datée et sourcée pour garantir la fiabilité du récit.</p>
      </div>
      <div class="step reveal" data-delay="300">
        <span class="step__line"></span>
        <h4>Restitution &amp; transmission</h4>
        <p>Vous recevez un arbre, une synthèse et les copies d'actes, prêts à partager en famille.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============================ QUOTE ============================ -->
<section class="section band-ink">
  <div class="wrap">
    <figure class="quote reveal">
      <span class="quote__mark">&ldquo;</span>
      <blockquote>{page?.temoignage ?? "Catherine a retrouvé la trace de mon arrière-grand-père, parti d'un village du Libournais en 1889. Lire son acte de mariage, c'était comme lui serrer la main."}</blockquote>
      <figcaption>{page?.temoignageAuteur ?? "Hélène M. — Saint-Émilion"}</figcaption>
    </figure>
  </div>
</section>

<!-- ============================ BLOG TEASER ============================ -->
<section class="section">
  <div class="wrap">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;gap:24px;flex-wrap:wrap;margin-bottom:48px">
      <div style="max-width:560px">
        <span class="eyebrow reveal">Le carnet de recherches</span>
        <h2 class="reveal">Histoires d'archives &amp; méthode</h2>
      </div>
      <a class="link-arrow reveal" href="/blog">
        Tous les articles
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
    <div class="grid grid-3">
      <a class="post-card reveal" href="/blog">
        <div class="post-card__media">
          <svg class="archive-motif" viewBox="0 0 320 160" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <rect width="320" height="160" fill="#163E47"/>
            <g opacity="0.18" stroke="#E7E3D4" stroke-width="1">
              <path d="M40 30h240M40 50h240M40 70h180M40 90h240M40 110h150M40 130h210"/>
            </g>
            <text x="30" y="120" font-family="Spectral, serif" font-size="120" fill="#B0894B" opacity="0.22">G</text>
          </svg>
        </div>
        <div class="post-card__body">
          <span class="tag">Généathème</span>
          <h3>Les métiers oubliés de nos ancêtres girondins</h3>
          <p style="color:var(--ink-soft);font-size:.98rem">Tonneliers, gabariers, vignerons : ces professions disparues racontent la vie quotidienne au bord de la Dordogne.</p>
          <div class="post-meta"><span>12 mai 2026</span><span>· 6 min</span></div>
        </div>
      </a>
      <a class="post-card reveal" data-delay="100" href="/blog">
        <div class="post-card__media">
          <svg class="archive-motif" viewBox="0 0 320 160" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <rect width="320" height="160" fill="#163E47"/>
            <g opacity="0.16" stroke="#E7E3D4" stroke-width="1">
              <path d="M30 20h60v120h-60zM110 20h60v120h-60zM190 20h60v120h-60z"/>
            </g>
            <text x="200" y="120" font-family="Spectral, serif" font-size="120" fill="#B0603C" opacity="0.24">A</text>
          </svg>
        </div>
        <div class="post-card__body">
          <span class="tag">Challenge AZ</span>
          <h3>A comme Archives : par où commencer ses recherches</h3>
          <p style="color:var(--ink-soft);font-size:.98rem">Premier billet du Challenge AZ : les bons réflexes pour ouvrir une enquête généalogique sans se perdre.</p>
          <div class="post-meta"><span>2 nov. 2025</span><span>· 5 min</span></div>
        </div>
      </a>
      <a class="post-card reveal" data-delay="200" href="/blog">
        <div class="post-card__media">
          <svg class="archive-motif" viewBox="0 0 320 160" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <rect width="320" height="160" fill="#163E47"/>
            <g opacity="0.16" stroke="#E7E3D4" stroke-width="1" fill="none">
              <circle cx="160" cy="80" r="60"/>
              <circle cx="160" cy="80" r="40"/>
              <circle cx="160" cy="80" r="20"/>
            </g>
            <text x="120" y="118" font-family="Spectral, serif" font-size="120" fill="#7C9A78" opacity="0.3">F</text>
          </svg>
        </div>
        <div class="post-card__body">
          <span class="tag">Méthode</span>
          <h3>Lire un acte ancien : déchiffrer l'écriture du XVIIIᵉ siècle</h3>
          <p style="color:var(--ink-soft);font-size:.98rem">Abréviations, formules latines, graphies surprenantes : petit guide pour apprivoiser la paléographie.</p>
          <div class="post-meta"><span>18 mars 2026</span><span>· 8 min</span></div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ============================ CTA ============================ -->
<section class="section band-paper2 band-edge-top">
  <div class="wrap narrow" style="text-align:center">
    <div class="rule-orn reveal" style="margin-bottom:36px"><span class="diamond"></span></div>
    <h2 class="reveal">Et si l'on remontait le temps ensemble ?</h2>
    <p class="reveal lead" style="margin:0 auto 32px;max-width:52ch">Confiez-moi un nom, une date, une vieille photo. Le premier échange est sans engagement — racontez-moi ce que vous cherchez.</p>
    <div class="reveal hero__cta" style="justify-content:center" data-delay="80">
      <a class="btn btn--primary" href="/contact">Prendre contact</a>
      <a class="btn btn--ghost" href="/services">Voir les prestations</a>
    </div>
  </div>
</section>

</Base>
