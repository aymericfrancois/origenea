---
import Base from '../layouts/Base.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Origenea — Cabinet de généalogie familiale",
  "image": "https://www.origenea.fr/assets/origenea-logo.png",
  "founder": "Catherine Fougeray-Imbrechts",
  "areaServed": ["Libourne", "Saint-Émilion", "Bordeaux", "Gironde", "Nouvelle-Aquitaine"],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "12 rue Montesquieu",
    "addressLocality": "Libourne",
    "postalCode": "33500",
    "addressRegion": "Gironde",
    "addressCountry": "FR"
  },
  "telephone": "+33557251234",
  "email": "contact@origenea.fr",
  "url": "https://www.origenea.fr",
  "openingHours": "Mo-Fr 09:00-18:00"
});
---

<Base
  title="Contact — Origenea, généalogiste à Libourne (Gironde)"
  description="Contactez Catherine Fougeray-Imbrechts, cabinet de généalogie Origenea à Libourne (33500). Premier échange gratuit pour votre recherche familiale, foncière ou successorale en Gironde."
  currentPage="contact"
  footerVariant="contact"
  schema={schema}
>

<!-- ============================ PAGE HERO ============================ -->
<section class="page-hero">
  <div class="wrap">
    <span class="eyebrow reveal">Contact</span>
    <h1 class="reveal">Racontez-moi ce que vous cherchez</h1>
    <p class="lead reveal">Un nom, une date, une vieille photo, une intuition… Tout est un bon point de départ. Le premier échange est gratuit et sans engagement.</p>
  </div>
</section>

<!-- ============================ FORM + INFOS ============================ -->
<section class="section--tight" style="padding-bottom:clamp(64px,9vw,120px)">
  <div class="wrap layout-split" style="align-items:start">

    <!-- Formulaire -->
    <div class="reveal">
      <div class="card" style="background:var(--paper-2);padding:clamp(28px,4vw,44px)">
        <h2 style="font-size:clamp(1.5rem,2.4vw,2rem);margin-bottom:1em">Votre demande</h2>
        <form onsubmit="return false" novalidate>
          <div class="field-row">
            <div class="field">
              <label for="prenom">Prénom</label>
              <input id="prenom" type="text" placeholder="Votre prénom" />
            </div>
            <div class="field">
              <label for="nom">Nom</label>
              <input id="nom" type="text" placeholder="Votre nom" />
            </div>
          </div>
          <div class="field-row">
            <div class="field">
              <label for="email">E-mail</label>
              <input id="email" type="email" placeholder="vous@exemple.fr" />
            </div>
            <div class="field">
              <label for="tel">
                Téléphone <span style="color:var(--ink-soft);font-weight:400">(facultatif)</span>
              </label>
              <input id="tel" type="tel" placeholder="06 00 00 00 00" />
            </div>
          </div>
          <div class="field">
            <label for="sujet">Type de recherche</label>
            <select id="sujet">
              <option>Généalogie familiale</option>
              <option>Généalogie foncière</option>
              <option>Sous-traitance successorale</option>
              <option>Je ne sais pas encore</option>
            </select>
          </div>
          <div class="field">
            <label for="message">Votre projet</label>
            <textarea id="message" placeholder="Décrivez ce que vous savez déjà et ce que vous aimeriez retrouver…"></textarea>
          </div>
          <button class="btn btn--primary" type="submit" style="width:100%;justify-content:center">
            Envoyer ma demande
          </button>
          <p style="margin-top:14px;text-align:center;font-size:.88rem;color:var(--ink-soft)">
            Formulaire de démonstration — pour un échange réel, écrivez à contact@origenea.fr.
          </p>
        </form>
      </div>
    </div>

    <!-- Coordonnées -->
    <div class="reveal" data-delay="120">
      <span class="eyebrow">Le cabinet</span>
      <h2 style="font-size:clamp(1.5rem,2.4vw,2rem);margin-bottom:1.2em">Coordonnées</h2>
      <ul class="info-list">
        <li>
          <span class="ic">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M12 21s-7-4.5-7-10a7 7 0 0114 0c0 5.5-7 10-7 10z" stroke-linejoin="round"/>
              <circle cx="12" cy="11" r="2.4"/>
            </svg>
          </span>
          <div>
            <div class="lbl">Adresse</div>
            <div class="val">12 rue Montesquieu<br />33500 Libourne, Gironde</div>
          </div>
        </li>
        <li>
          <span class="ic">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M5 4h4l2 5-2.5 1.5a11 11 0 005 5L20 13l1 4v2a1 1 0 01-1 1A16 16 0 014 5a1 1 0 011-1z" stroke-linejoin="round"/>
            </svg>
          </span>
          <div>
            <div class="lbl">Téléphone</div>
            <div class="val"><a href="tel:+33557251234">05 57 25 12 34</a></div>
          </div>
        </li>
        <li>
          <span class="ic">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="M4 7l8 6 8-6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <div>
            <div class="lbl">E-mail</div>
            <div class="val"><a href="mailto:contact@origenea.fr">contact@origenea.fr</a></div>
          </div>
        </li>
        <li>
          <span class="ic">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <circle cx="12" cy="12" r="9"/>
              <path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <div>
            <div class="lbl">Horaires</div>
            <div class="val">
              Du lundi au vendredi, 9h–18h<br />
              <span style="color:var(--ink-soft);font-size:.95rem">Rendez-vous en visioconférence ou sur place</span>
            </div>
          </div>
        </li>
      </ul>

      <!-- Carte stylisée -->
      <div class="map-card reveal" data-delay="160" style="margin-top:28px">
        <svg viewBox="0 0 520 300" preserveAspectRatio="xMidYMid slice" style="width:100%;height:100%;display:block" aria-label="Localisation à Libourne, Gironde">
          <rect width="520" height="300" fill="#E7E3D4"/>
          <g stroke="#C9C2AC" stroke-width="1" opacity="0.8">
            <path d="M0 60h520M0 120h520M0 180h520M0 240h520M80 0v300M180 0v300M280 0v300M380 0v300M460 0v300"/>
          </g>
          <path d="M-10 210 C 120 180, 200 240, 300 200 S 460 150, 540 190" fill="none" stroke="#7C9A78" stroke-width="6" opacity="0.55"/>
          <path d="M-10 215 C 120 185, 200 245, 300 205 S 460 155, 540 195" fill="none" stroke="#9FB89B" stroke-width="2" opacity="0.6"/>
          <circle cx="262" cy="150" r="30" fill="#163E47" opacity="0.08"/>
          <path d="M262 122c-9 0-16 7-16 16 0 11 16 26 16 26s16-15 16-26c0-9-7-16-16-16z" fill="#B0603C"/>
          <circle cx="262" cy="138" r="5.5" fill="#F1F1E6"/>
          <text x="262" y="195" text-anchor="middle" font-family="Schibsted Grotesk, sans-serif" font-weight="600" font-size="15" fill="#163E47" letter-spacing="0.5">Libourne</text>
          <text x="262" y="214" text-anchor="middle" font-family="Hanken Grotesk, sans-serif" font-size="11" fill="#4B5F63">Gironde · Nouvelle-Aquitaine</text>
        </svg>
      </div>
    </div>
  </div>
</section>

<!-- ============================ ZONE D'INTERVENTION ============================ -->
<section class="section band-paper2 band-edge-top band-edge-bottom">
  <div class="wrap" style="text-align:center">
    <span class="eyebrow reveal" style="justify-content:center">Zone d'intervention</span>
    <h2 class="reveal" style="margin-bottom:.6em">Au plus près de vos racines girondines</h2>
    <p class="reveal lead" style="max-width:60ch;margin:0 auto 36px">Basée à Libourne, j'interviens sur place dans tout le département et mène des recherches à distance partout en France.</p>
    <div class="reveal pills" data-delay="80">
      <span class="pill">Libourne</span>
      <span class="pill">Saint-Émilion</span>
      <span class="pill">Coutras</span>
      <span class="pill">Castillon-la-Bataille</span>
      <span class="pill">Bordeaux</span>
      <span class="pill">Arcachon</span>
      <span class="pill">Blaye</span>
      <span class="pill">Toute la Gironde</span>
      <span class="pill">Nouvelle-Aquitaine</span>
    </div>
  </div>
</section>

</Base>
