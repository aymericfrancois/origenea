---
import Base from '../layouts/Base.astro';
import {
  getPosts,
  urlFor,
  excerptFromBlocks,
  readingTime,
  formatDateFr,
} from '../lib/sanity';

const posts = await getPosts();
const [featured, ...rest] = posts;
---

<Base
  title="Le carnet de recherches — blog de généalogie | Origenea, Libourne"
  description="Le blog du cabinet Origenea : Généathème, Challenge AZ, méthode de recherche et histoires d'archives en Gironde. Conseils de Catherine Fougeray-Imbrechts, généalogiste à Libourne."
  currentPage="blog"
  footerVariant="blog"
>

<!-- ============================ PAGE HERO ============================ -->
<section class="page-hero">
  <div class="wrap">
    <span class="eyebrow reveal">Le carnet de recherches</span>
    <h1 class="reveal">Histoires d'archives &amp; méthode</h1>
    <p class="lead reveal">Mes trouvailles, mes coups de cœur et mes conseils pour mener vos propres recherches. Je participe au <strong>Généathème</strong> et au <strong>Challenge AZ</strong> — deux rendez-vous de la communauté des généalogistes.</p>
  </div>
</section>

{posts.length === 0 ? (
  <!-- ============================ ÉTAT VIDE ============================ -->
  <section class="section--tight">
    <div class="wrap narrow" style="text-align:center">
      <p class="lead">Aucun article pour le moment. Revenez bientôt !</p>
    </div>
  </section>
) : (
  <>
  <!-- ============================ ARTICLE À LA UNE ============================ -->
  <section class="section--tight">
    <div class="wrap">
      <a class="post-feature reveal" href={`/blog/${featured.slug}`}>
        <div class="post-feature__media">
          {featured.image ? (
            <img
              src={urlFor(featured.image).width(960).height(630).fit('crop').auto('format').url()}
              alt={featured.image.alt || featured.title}
              style="width:100%;height:100%;object-fit:cover"
            />
          ) : (
            <svg viewBox="0 0 640 420" preserveAspectRatio="xMidYMid slice" aria-hidden="true" style="width:100%;height:100%">
              <rect width="640" height="420" fill="#163E47"/>
              <g opacity="0.14" stroke="#E7E3D4" stroke-width="1.2">
                <path d="M60 70h520M60 110h520M60 150h400M60 190h520M60 230h300M60 270h520M60 310h440M60 350h360"/>
              </g>
              <text x="40" y="360" font-family="Spectral, serif" font-size="360" fill="#B0894B" opacity="0.18">G</text>
            </svg>
          )}
        </div>
        <div class="post-feature__body">
          <span class="tag">À la une</span>
          <h2>{featured.title}</h2>
          <p class="lead">{excerptFromBlocks(featured.content, 220)}</p>
          <div class="post-meta" style="margin-top:24px">
            <span>{formatDateFr(featured.date)}</span>
            <span>· {readingTime(featured.content)} min de lecture</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ============================ GRILLE D'ARTICLES ============================ -->
  {rest.length > 0 && (
    <section class="section--tight" style="padding-top:8px">
      <div class="wrap">
        <div class="grid grid-3">
          {rest.map((post, i) => (
            <a class="post-card reveal" data-delay={(i % 3) * 80} href={`/blog/${post.slug}`}>
              <div class="post-card__media">
                {post.image ? (
                  <img
                    src={urlFor(post.image).width(640).height(320).fit('crop').auto('format').url()}
                    alt={post.image.alt || post.title}
                    style="width:100%;height:100%;object-fit:cover"
                  />
                ) : (
                  <svg class="archive-motif" viewBox="0 0 320 160" preserveAspectRatio="xMidYMid slice">
                    <rect width="320" height="160" fill="#163E47"/>
                    <g opacity="0.16" stroke="#E7E3D4" stroke-width="1">
                      <path d="M30 20h60v120h-60zM110 20h60v120h-60zM190 20h60v120h-60z"/>
                    </g>
                    <text x="205" y="120" font-family="Spectral, serif" font-size="120" fill="#B0603C" opacity="0.26">{post.title.charAt(0).toUpperCase()}</text>
                  </svg>
                )}
              </div>
              <div class="post-card__body">
                <h3>{post.title}</h3>
                <p style="color:var(--ink-soft);font-size:.98rem">{excerptFromBlocks(post.content)}</p>
                <div class="post-meta"><span>{formatDateFr(post.date)}</span><span>· {readingTime(post.content)} min</span></div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
  </>
)}

<!-- ============================ NEWSLETTER ============================ -->
<section class="section band-paper2 band-edge-top band-edge-bottom">
  <div class="wrap narrow" style="text-align:center">
    <div class="rule-orn reveal" style="margin-bottom:32px"><span class="diamond"></span></div>
    <h2 class="reveal">Suivez le fil de mes recherches</h2>
    <p class="reveal lead" style="margin:0 auto 28px;max-width:48ch">Recevez les nouveaux articles et mes trouvailles d'archives, une fois par mois, sans jamais d'envahissement.</p>
    <form class="reveal newsletter" data-delay="80" onsubmit="return false">
      <input type="email" aria-label="Votre adresse e-mail" placeholder="vous@exemple.fr" required />
      <button class="btn btn--primary" type="submit">M'abonner</button>
    </form>
    <p class="reveal" data-delay="160" style="margin-top:14px;font-size:.88rem;color:var(--ink-soft)">Formulaire de démonstration — aucune donnée n'est collectée.</p>
  </div>
</section>

</Base>
