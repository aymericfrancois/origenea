---
interface Props {
  currentPage: string;
}
const { currentPage } = Astro.props;

const nav = [
  { href: '/', label: 'Accueil', id: 'index' },
  { href: '/services', label: 'Services', id: 'services' },
  { href: '/a-propos', label: 'À propos', id: 'a-propos' },
  { href: '/blog', label: 'Blog', id: 'blog' },
  { href: '/contact', label: 'Contact', id: 'contact' },
];
---

<header class="site-header">
  <div class="wrap site-header__inner">
    <a class="brand" href="/" aria-label="Origenea — accueil">
      <svg class="brand__mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <circle cx="24" cy="24" r="22.5" stroke="currentColor" stroke-width="1.2" opacity="0.4"/>
        <path d="M24 38V20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <path d="M24 24c-3-2-5-5-5-8 0-2 1.2-3.6 2.6-4.6M24 24c3-2 5-5 5-8 0-2-1.2-3.6-2.6-4.6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        <path d="M24 28c-3.2-1-7-1.4-9.4-3.4M24 28c3.2-1 7-1.4 9.4-3.4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        <circle cx="24" cy="9" r="2.1" fill="currentColor"/>
        <circle cx="14" cy="22.5" r="1.8" fill="currentColor"/>
        <circle cx="34" cy="22.5" r="1.8" fill="currentColor"/>
        <path d="M17 39.5h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
      <span class="brand__word">
        <span class="brand__name">Origenea</span>
        <span class="brand__tag">Histoire · Famille</span>
      </span>
    </a>
    <nav class="nav" aria-label="Navigation principale">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={currentPage === item.id ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="header-cta">
      <a class="btn btn--primary" href="/contact">Prendre contact</a>
    </div>
    <button class="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <nav class="mobile-nav" aria-label="Navigation mobile">
    {nav.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
    <a class="btn btn--primary" href="/contact">Prendre contact</a>
  </nav>
</header>
